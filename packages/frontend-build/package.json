{
  "name": "@citizens/frontend-build",
  "version": "0.1.0",
  "private": true,
  "description": "Shared static-frontend build pipeline for Citizens ecosystem apps — esbuild JSX precompile → hashed bundles → index.html rewrite → env-driven config.js. Host apps inject their own esbuild instance.",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "node --check index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"index.js\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "esbuild": ">=0.20.0"
  },
  "devDependencies": {
    "@citizens/config": "workspace:*",
    "@types/node": "20.19.0",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/coverage-v8": "3.2.6",
    "esbuild": "^0.25.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "typescript": "5.5.4",
    "vitest": "3.2.6"
  }
}
