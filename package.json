{
  "name": "citizens",
  "version": "0.1.0",
  "private": true,
  "description": "Citizens ecosystem monorepo - Connect (discovery), Vision (impact intelligence), Wear (Kingdom fashion social) on one shared Supabase data plane",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@types/node": "20.19.0",
    "prettier": "3.3.3",
    "turbo": "2.9.14",
    "typescript": "7.0.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "postcss": "8.5.10",
      "eslint-config-next>@typescript-eslint/parser": "^8.58.0",
      "eslint-config-next>@typescript-eslint/eslint-plugin": "^8.58.0",
      "vitest@<3.2.6": ">=3.2.6",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "vite@>=7.0.0 <=7.3.4": ">=7.3.5",
      "js-yaml@>=4.0.0 <=4.1.1": ">=4.2.0"
    }
  }
}
