{
  "name": "citizens",
  "version": "0.1.0",
  "private": true,
  "description": "Citizens ecosystem monorepo - Connect (discovery), Vision (impact intelligence), Wear (Kingdom fashion social) on one shared Supabase data plane",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@types/node": "20.19.0",
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.5.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "postcss": "8.5.10"
    }
  }
}
