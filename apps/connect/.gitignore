# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.tmp-vitest.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# HTML frontend per-environment runtime config (config.example.js is committed)
/src/frontend/config.js

# Generated frontend build artifacts (scripts/build-frontend.js copies src/frontend/* here at build time)
# The original source files live in src/frontend/ — these public/ copies are ephemeral build outputs.
# auth-client.*.js / capacitor-bridge.*.js are content-hashed (addendum §B0) — glob, not a fixed name.
/public/index.html
/public/auth-client.js
/public/auth-client.*.js
/public/capacitor-bridge.*.js
/public/config.js
/public/config.example.js
/public/app/
/public/supabase-auth.js

# vercel
.vercel

# typescript
*.tsbuildinfo

# capacitor native builds
/android/app/build/
/ios/App/Pods/
next-env.d.ts

