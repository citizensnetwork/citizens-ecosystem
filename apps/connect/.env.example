# ─── MapTiler Cloud ──────────────────────────────────────────
# Required for the branded Kingdom Commons map style.
# Get your key at: https://cloud.maptiler.com/account/keys/
# If not set, the map falls back to free OSM raster tiles.
NEXT_PUBLIC_MAPTILER_KEY=REPLACE_WITH_YOUR_MAPTILER_KEY
NEXT_PUBLIC_MAPTILER_STYLE=REPLACE_WITH_YOUR_MAPTILER_STYLE_UUID

# ─── HTML frontend (cross-origin) ────────────────────────────
# The standalone HTML/React frontend (src/frontend/) calls this API cross-origin.
# Set this to the deployed frontend's exact origin (scheme + host, no trailing slash)
# so credentialed (cookie) requests are allowed. Open question F3 — fill before the
# HTML frontend deploys to production. Local dev falls back to http://localhost:3001.
# ALLOWED_FRONTEND_ORIGIN=https://your-frontend-domain.com

# ─── Upstash Redis (rate limiting — addendum §A2) ────────────
# Free tier: https://console.upstash.com/ → Create Database → REST API section.
# Both must be set for the shared multi-instance limiter to activate; if either
# is absent, src/lib/rate-limit.ts transparently falls back to the (single-
# instance) in-memory limiter — safe for local dev, NOT safe for prod at scale.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_YOUR_UPSTASH_REST_TOKEN

# ─── Vercel (auto-injected — do not set manually) ────────────
# NEXT_PUBLIC_VERCEL_URL is set by Vercel automatically.

# ─── Future: PayFast (not yet implemented) ───────────────────
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
