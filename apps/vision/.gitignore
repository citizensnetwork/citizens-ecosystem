# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# editor
.vscode/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp test/coverage files
coverage_out.txt
coverage_review.txt
test_run*.txt

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# HTML frontend per-environment runtime config (config.example.js is committed)
/src/frontend/config.js

# Generated frontend build artifacts (scripts/build-frontend.js copies
# src/frontend/* into public/ at build time; hashed bundles + config.js).
# The source of truth lives in src/frontend/ — public/ is ephemeral output.
/public/index.html
/public/auth-client.js
/public/auth-client.*.js
/public/capacitor-bridge.*.js
/public/config.js
/public/config.example.js
/public/app/

.vercel
.env*
